PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# MongoDB (Atlas) — usar connection string estándar, NO mongodb+srv en Windows
# Formato: mongodb://usuario:password@host:27017/red-social?ssl=true&authSource=admin&retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/red-social

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=cambia-esto-en-produccion-generar-clave-segura
JWT_EXPIRES_IN=15m

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# CORS en producción (separar por coma)
# CORS_ORIGINS=https://tu-frontend.vercel.app

# Cloudinary (requerido para subir imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
